        <mxCell id="ZrCcDs8qdRbTNWONpvc0-6" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Non Functional Requirements&lt;/h1&gt;&lt;div&gt;&lt;div&gt;Scalability&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Handle 100 Million DAU&lt;/div&gt;&lt;div&gt;Read-heavy system (search ≫ booking)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;High Availability (Search)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Event browsing should never fail&lt;/div&gt;&lt;div&gt;Slightly stale data acceptable (event listings, seat counts)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;High Consistency (Booking)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Strong consistency for seat booking&lt;/div&gt;&lt;div&gt;No double booking allowed&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Performance&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Search latency &amp;lt; 200ms&lt;/div&gt;&lt;div&gt;Booking latency &amp;lt; 2–3 seconds&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Reliability&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Fault-tolerant microservices&lt;/div&gt;&lt;div&gt;Retry mechanisms for payments&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Security&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Secure payments&lt;/div&gt;&lt;div&gt;Authentication &amp;amp; authorization&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="500" width="560" x="-360" y="140" as="geometry" />
        </mxCell>
        <mxCell id="ZrCcDs8qdRbTNWONpvc0-7" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;APIs&lt;/h1&gt;&lt;div&gt;GET /events?title=&amp;amp;city=&amp;amp;date=&lt;br data-start=&quot;132&quot; data-end=&quot;135&quot;&gt;&lt;br/&gt;GET /events/{event_id}&lt;br data-start=&quot;157&quot; data-end=&quot;160&quot;&gt;&lt;br/&gt;GET /events/{event_id}/seats&lt;br data-start=&quot;188&quot; data-end=&quot;191&quot;&gt;&lt;br/&gt;POST /bookings/hold (user_id, event_id, seats[])&lt;br data-start=&quot;239&quot; data-end=&quot;242&quot;&gt;&lt;br/&gt;POST /bookings/confirm&lt;br data-start=&quot;264&quot; data-end=&quot;267&quot;&gt;&lt;br/&gt;POST /payments&lt;/div&gt;" vertex="1">
